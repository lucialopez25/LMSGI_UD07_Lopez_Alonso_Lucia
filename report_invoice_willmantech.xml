<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_invoice_willmantech_document">
            <t t-call="web.external_layout">
                <div class="page">
                    
                    <h2>
                        <span>Factura WillmanTech S.L. - </span>
                        <span t-field="doc.name"/>
                    </h2>
                    
                    <div class="row mt32 mb32" id="informations">
                        <div class="col-auto mw-100 mb-2">
                            <strong>Fecha de emisión:</strong>
                            <p class="m-0" t-field="doc.date"/>
                        </div>
                    </div>
                    
                    <t t-set="display_discount" t-value="any(line.discount for line in doc.invoice_line_ids)"/>
                    
                    <table class="table table-sm o_main_table" name="invoice_line_table">
                        <thead>
                            <tr>
                                <th name="th_description" class="text-left">Descripción</th>
                                <th name="th_quantity" class="text-right">Cantidad</th>
                                <th name="th_priceunit" class="text-right">Precio Unitario</th>
                                
                                <th name="th_discount" t-if="display_discount" class="text-right">
                                    <span>Descuento (%)</span>
                                </th>
                                
                                <th name="th_subtotal" class="text-right">
                                    <span>Subtotal</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody class="invoice_tbody">
                            
                            <t t-foreach="doc.invoice_line_ids" t-as="line">
                                <tr>
                                    <td name="account_invoice_line_name">
                                        <span t-field="line.name"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.quantity"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.price_unit"/>
                                    </td>
                                    
                                    <td t-if="display_discount" class="text-right">
                                        <span t-field="line.discount"/>
                                    </td>
                                    
                                    <td class="text-right o_price_total">
                                        <span t-field="line.price_subtotal"/>
                                    </td>
                                </tr>
                            </t>
                            
                        </tbody>
                    </table>
                    
                    <div class="clearfix">
                        <div id="total" class="row">
                            <div class="col-4 offset-8">
                                <table class="table table-sm" style="page-break-inside: avoid;">
                                    <tr class="border-black o_total">
                                        <td><strong>Total Neto</strong></td>
                                        <td class="text-right">
                                            <span t-field="doc.amount_total"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </t>
        </template>
    </data>
</odoo>